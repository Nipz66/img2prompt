{
  "manifest_version": 3,
  "name": "Image to Prompt — Innowebic",
  "version": "1.0.0",
  "description": "Right-click any image to generate a detailed AI prompt with Claude.",
  "permissions": ["contextMenus"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
